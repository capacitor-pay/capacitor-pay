{
  "name": "capacitor-pay",
  "version": "0.0.1",
  "description": "Provider-agnostic payments layer for Capacitor apps (Omnipay-style). Install alongside a provider package such as capacitor-pay-sumup.",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "dist/"
  ],
  "author": "Alessio Spanu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Spanu18/capacitor-pay.git"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "payments",
    "sumup",
    "omnipay"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/core": "^8.1.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "typescript": "~5.6.3"
  },
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0"
  },
  "dependencies": {
    "capacitor-pay-adyen": "file:../capacitor-pay-adyen",
    "capacitor-pay-stripe": "file:../capacitor-pay-stripe",
    "capacitor-pay-sumup": "file:../capacitor-pay-sumup",
    "currency-codes-ts": "^3.0.0"
  }
}
